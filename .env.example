# Database (SQLite, local file)
INKFLOW_DATABASE_URL=file:./prisma/dev.db

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-string"

# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_CHECKOUT_SUCCESS_URL=""
STRIPE_CHECKOUT_CANCEL_URL=""
STRIPE_PRICE_10_CREDITS=""
STRIPE_PRICE_50_CREDITS=""
STRIPE_PRICE_200_CREDITS=""
# Recurring Price ID for Studio Pro Monthly (required for subscriptions)
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_ENABLE_WALLET_PAY="true"

# Optional: OpenAI for natural-language signature tuning (falls back to rules if unset)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Seed users (run npm run db:seed):
#   studio@inkflow.ai / inkflow2024  (demo)
#   admin@inkflow.ai / admin2024     (admin refunds at /admin/purchases)
