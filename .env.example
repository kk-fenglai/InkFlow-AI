# Database — Neon PostgreSQL (https://neon.tech)
# Pooled connection (Vercel / serverless runtime)
INKFLOW_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Direct connection (Prisma migrations — Neon dashboard → Connection → Direct)
INKFLOW_DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-string"

# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_CHECKOUT_SUCCESS_URL=""
STRIPE_CHECKOUT_CANCEL_URL=""
STRIPE_PRICE_20_CREDITS=""
STRIPE_PRICE_50_CREDITS=""
STRIPE_PRICE_120_CREDITS=""
# Recurring Price ID for Studio Pro Monthly (required for subscriptions)
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_ENABLE_WALLET_PAY="true"

# AI natural-language tune — DeepSeek (recommended)
# Get API key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
# DEEPSEEK_API_BASE="https://api.deepseek.com"

# Optional: OpenAI-compatible provider (used only if DEEPSEEK_API_KEY is unset)
# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"
# OPENAI_BASE_URL="https://api.openai.com"

# Seed users (run npm run db:seed):
