INKFLOW_DATABASE_URL=postgresql://USER:PASS@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
INKFLOW_DATABASE_URL_UNPOOLED=postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

NEXTAUTH_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_20_CREDITS=
STRIPE_PRICE_50_CREDITS=
STRIPE_PRICE_120_CREDITS=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_ENABLE_WALLET_PAY=true

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

